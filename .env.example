# ---------- Site ----------
SITE_TITLE=Stackdock
# The public URL where this app is reachable (used in Discord links + the RSS feed)
PUBLIC_BASE_URL=https://example.com
# Signs login session cookies. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-long-random-secret
# Seeds the FIRST admin account on an empty database (change password after first login)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=pick-a-strong-password
# Generate with: openssl rand -hex 24
FEED_TOKEN=replace-with-long-random-token

# ---------- Collector inbox (Substack articles arrive here) ----------
# Example shown for Gmail. Use an app password, not your real password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.collector.inbox@gmail.com
IMAP_PASS=your-app-password
IMAP_FOLDER=INBOX
IMAP_ALLOWED_SENDER_DOMAINS=substack.com,substackcdn.com

# ---------- Podcast feeds ----------
# JSON map of display name -> RSS url. Put your Substack *private* podcast feed
# URLs and any Gumroad product RSS URLs here.
PODCAST_FEEDS={"My Substack Podcast": "https://api.substack.com/feed/podcast/XXXX/private/YYYY.rss"}

# ---------- Object storage (Cloudflare R2 shown; any S3-compatible works) ----------
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=stackdock
# Optional: custom/public domain serving the bucket. Leave blank to use presigned URLs.
S3_PUBLIC_BASE_URL=
PRESIGN_EXPIRY_SECONDS=604800

# ---------- Discord ----------
DISCORD_WEBHOOK_URL=

# ---------- Poll intervals (minutes) ----------
EMAIL_POLL_MINUTES=10
PODCAST_POLL_MINUTES=30
GUMROAD_POLL_MINUTES=360

# ---------- Substack cookie sync ----------
# Members connect their own accounts in the UI at /accounts (no env needed).
# Max posts backfilled per publication on an account's first sync:
SUBSTACK_BACKFILL_POSTS=50
SUBSTACK_POLL_MINUTES=60
