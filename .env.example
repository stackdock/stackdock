# ---------- Site ----------
SITE_TITLE=Stackdock
# The public URL where this app is reachable (used in Discord links + the RSS feed)
PUBLIC_BASE_URL=https://example.com
# Signs login session cookies. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-long-random-secret
# Seeds the FIRST admin account on an empty database (change password after first login)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=pick-a-strong-password
# Generate with: openssl rand -hex 24
FEED_TOKEN=replace-with-long-random-token

# ---------- Collector inbox (Substack articles arrive here) ----------
# Example shown for Gmail. Use an app password, not your real password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.collector.inbox@gmail.com
IMAP_PASS=your-app-password
IMAP_FOLDER=INBOX
IMAP_ALLOWED_SENDER_DOMAINS=substack.com,substackcdn.com

# ---------- Podcast feeds ----------
# JSON map of display name -> RSS url. Put your Substack *private* podcast feed
# URLs here (publication page -> Private RSS feed, or substack.com/account/settings).
PODCAST_FEEDS={"My Substack Podcast": "https://api.substack.com/feed/podcast/XXXX/private/YYYY.rss"}

# ---------- Object storage (Cloudflare R2 shown; any S3-compatible works) ----------
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=stackdock
# Optional: custom/public domain serving the bucket. Leave blank to use presigned URLs.
S3_PUBLIC_BASE_URL=
PRESIGN_EXPIRY_SECONDS=604800

# ---------- Cloud metrics on /status (optional, read-only tokens) ----------
# Cloudflare: dash.cloudflare.com/profile/api-tokens -> Create Token -> Custom
#   -> permission: Account / Account Analytics / Read. Account ID: shown on the R2 overview page.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# DigitalOcean: cloud.digitalocean.com -> API (left sidebar) -> Generate New Token (READ scope only).
# Droplet ID: the number in your droplet's dashboard URL (cloud.digitalocean.com/droplets/<ID>).
DO_API_TOKEN=
DO_DROPLET_ID=

# ---------- Discord ----------
DISCORD_WEBHOOK_URL=
# Optional: POST one combined JSON payload of all new items per sync to this URL
OUTBOUND_WEBHOOK_URL=

# ---------- Poll intervals (minutes) ----------
EMAIL_POLL_MINUTES=10
PODCAST_POLL_MINUTES=30

# ---------- Substack cookie sync ----------
# Members connect their own accounts in the UI at /accounts (no env needed).
# Max posts backfilled per publication on an account's first sync:
SUBSTACK_BACKFILL_POSTS=50
SUBSTACK_POLL_MINUTES=60
# Publications Substack's subscriptions API doesn't return (some paid / podcast
# subs). JSON list of {"name","base_url"} synced for EVERY connected account.
# Example: [{"name":"Night Owls","base_url":"https://www.nightowls.biz"}]
SUBSTACK_EXTRA_PUBS=[]
# Re-alert in Discord every N hours while a cookie stays stale (0 = once only)
STALE_REMINDER_HOURS=24
# Locked-preview refresh: re-fetch paid previews a member now pays for and unlock
# them, every N hours (0 disables). MAX caps posts probed per run. LOCK_WAIT is
# how long the refresh/verify passes wait for an in-flight sync before giving up.
SUBSTACK_REFRESH_HOURS=12
SUBSTACK_REFRESH_MAX=150
SUBSTACK_LOCK_WAIT=900

# ---------- Data / feeds ----------
# Where the SQLite DB lives (the compose volume mounts /data).
DATA_DIR=/data
# Optional: repo slug + workflow files for the /status CI badges.
GITHUB_REPO=youruser/stackdock
GITHUB_WORKFLOWS=ci.yml,deploy.yml

# ---------- Patreon (optional; per-member cookie added in /accounts) ----------
PATREON_POLL_MINUTES=60
PATREON_BACKFILL_POSTS=30

# ---------- YouTube (optional) ----------
# Comma-separated default channel handles (no @); members add more in the UI.
YOUTUBE_DEFAULT_CHANNELS=
YOUTUBE_POLL_MINUTES=30

# ---------- NYT gated-article pull (optional; needs a residential proxy) ----------
NYT_COOKIE=
NYT_POLL_MINUTES=5
NYT_BROWSER_TRIES=3
NYT_FETCH_POLL_TRIES=40
NYT_PROXY_SERVER=
NYT_PROXY_USER=
NYT_PROXY_PASS=
NYT_PROXY_SESSION_PREFIX=stackdock
NYT_PROXY_STICKY_MINUTES=10
NYT_PROXY_MAX_TRIES=4

# ---------- mde.tv (optional) ----------
MDE_API_BASE=
MDE_EMAIL=
MDE_PASSWORD=
MDE_ACCESS_TOKEN=
MDE_REFRESH_TOKEN=
MDE_POLL_MINUTES=1440
MDE_CACHE_SECONDS=300
